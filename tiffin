    const activeRows=data.rows.filter(r=>r.amt>0);
    if(activeRows.length){
      const cols=[28,10,10,10,16,18],heads=['Date','B','L','D','Extra','Total'],sx=lm;
      doc.setFillColor(215,235,245);doc.rect(sx,yp,cw,6,'F');doc.setFontSize(8);doc.setFont('helvetica','bold');doc.setTextColor(20,80,150);let cx=sx+2;heads.forEach((h,i)=>{doc.text(h,cx,yp+4.5);cx+=cols[i];});yp+=6;doc.setFont('helvetica','normal');doc.setTextColor(40,40,40);
      activeRows.forEach((row,ri)=>{if(yp>275)addPage();if(ri%2===0){doc.setFillColor(250,252,250);doc.rect(sx,yp,cw,5.5,'F');}doc.setFontSize(8);cx=sx+2;[row.date,row.b?'Y':'',row.l?'Y':'',row.d?'Y':'',row.e||'','Rs.'+row.amt].forEach((v,i)=>{doc.text(String(v),cx,yp+4);cx+=cols[i];});yp+=5.5;});
      doc.setFillColor(234,245,239);doc.rect(lm,yp,cw,6,'F');doc.setFontSize(8.5);doc.setFont('helvetica','bold');cx=lm+2;doc.setTextColor(14,74,49);doc.text('Monthly Total',cx,yp+4.5);cx+=92;doc.text('Rs.'+data.totalAmt,cx,yp+4.5);yp+=6;
      doc.setFillColor(234,240,250);doc.rect(lm,yp,cw,6,'F');cx=lm+2;doc.setTextColor(26,95,138);doc.text('Paid Amount',cx,yp+4.5);cx+=92;doc.text('Rs.'+data.paid,cx,yp+4.5);yp+=6;
      doc.setFillColor(253,240,238);doc.rect(lm,yp,cw,6,'F');cx=lm+2;doc.setTextColor(data.pending>0?192:14,data.pending>0?57:74,data.pending>0?43:49);doc.text('Pending Amount',cx,yp+4.5);cx+=92;doc.text('Rs.'+data.pending,cx,yp+4.5);yp+=6;
    }
    yp+=6;
  });
  // Add developer credit to PDF footer
  doc.setFontSize(7); doc.setTextColor(150,150,150); doc.setFont('helvetica','normal');
  doc.text('Developed by Antariksh Sawarbandhe', 105, 290, {align:'center'});
  doc.save(`TiffinTrack_${MONTHS[m]}_${y}.pdf`);
}

// ===================== EXPORT EXCEL =====================
function exportExcel() {
  const m=S.curMonth, y=S.curYear, wb=XLSX.utils.book_new();
  const rows=[['Date','Customer Name','Breakfast','Lunch','Dinner','Extra Tiffin','B Rate','L Rate','D Rate','Extra Rate','Daily Total','Paid Amount','Pending Amount','Remark']];
  S.customers.forEach(c=>{const data=getMonthlyData(c.id,m,y);data.rows.forEach(r=>{if(r.amt>0||r.b||r.l||r.d||r.e)rows.push([r.date,c.name,r.b?'Yes':'No',r.l?'Yes':'No',r.d?'Yes':'No',r.e,S.rates.b,S.rates.l,S.rates.d,S.rates.e,r.amt,'','','']);});rows.push([MONTHS[m]+' '+y+' Summary',c.name,'','','','','','','','',data.totalAmt,data.paid,data.pending,'Monthly Total']);rows.push([]);});
  rows.push([]); rows.push(['','Developed by Antariksh Sawarbandhe']);
  const ws=XLSX.utils.aoa_to_sheet(rows);ws['!cols']=[{wch:14},{wch:22},{wch:11},{wch:9},{wch:9},{wch:13},{wch:9},{wch:9},{wch:9},{wch:11},{wch:13},{wch:13},{wch:15},{wch:14}];
  XLSX.utils.book_append_sheet(wb,ws,MONTHS[m].slice(0,3)+' '+y);XLSX.writeFile(wb,`TiffinTrack_${MONTHS[m]}_${y}.xlsx`);
}

