// ===================== PASSWORD HELPERS =====================
function togglePwdEye(inputId, btn) {
  const inp = document.getElementById(inputId);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  btn.style.opacity = inp.type === 'text' ? '0.8' : '0.4';
}

function getPasswordStrength(pwd) {
  if(!pwd) return { score: 0, label: '', cls: '', pct: 0 };
  let score = 0;
  if(pwd.length >= 6) score++; if(pwd.length >= 10) score++;
  if(/[A-Z]/.test(pwd)) score++; if(/[0-9]/.test(pwd)) score++; if(/[^A-Za-z0-9]/.test(pwd)) score++;
  const levels = [
    {label:'',cls:''},
    {label:'Weak',cls:'strength-weak'},
    {label:'Fair',cls:'strength-fair'},
    {label:'Good',cls:'strength-good'},
    {label:'Strong',cls:'strength-strong'},
    {label:'Very Strong',cls:'strength-strong'}
  ];
  const lvl = levels[Math.min(score, 5)];
  return { score, label: lvl.label, cls: lvl.cls, pct: (score/5)*100 };
}

function checkStrength(account) {
  const el = document.getElementById('new-'+account+'-pass');
  if(!el) return;
  const str = getPasswordStrength(el.value);
  const bar = document.getElementById(account+'-strength-bar'), txt = document.getElementById(account+'-strength-text');
  if(bar) { bar.style.width = str.pct + '%'; bar.className = 'pwd-strength-bar ' + str.cls; }
  if(txt) { txt.textContent = str.label; txt.style.color = str.score >= 3 ? 'var(--primary)' : str.score >= 2 ? 'var(--accent-dark)' : 'var(--red)'; }
}

function checkMatch(account) {
  const p1el = document.getElementById('new-'+account+'-pass'), p2el = document.getElementById('confirm-'+account+'-pass'), hintEl = document.getElementById(account+'-match-hint');
  if(!p1el || !p2el || !hintEl) return;
  const p1 = p1el.value, p2 = p2el.value;
  if(!p2) { hintEl.textContent=''; return; }
  if(p1===p2) { hintEl.textContent='✓ Passwords match'; hintEl.style.color='var(--primary)'; }
  else { hintEl.textContent='✗ Passwords do not match'; hintEl.style.color='var(--red)'; }
}

function saveOnePassword(account) {
  if(currentUser && currentUser.role !== 'admin') { alert('Admin access required.'); return; }
  const newPass = document.getElementById('new-'+account+'-pass').value;
  const confPass = document.getElementById('confirm-'+account+'-pass').value;
  const fbEl = document.getElementById(account+'-pwd-feedback');
  fbEl.style.display = 'block';

  if(!newPass) { fbEl.innerHTML='<div style="background:var(--red-bg);border:1px solid rgba(192,57,43,0.2);border-radius:9px;padding:10px 14px;color:var(--red)">❌ Please enter a new password.</div>'; return; }
  if(newPass.length < 4) { fbEl.innerHTML='<div style="background:var(--red-bg);border:1px solid rgba(192,57,43,0.2);border-radius:9px;padding:10px 14px;color:var(--red)">❌ Password must be at least 4 characters.</div>'; return; }
  if(newPass !== confPass) { fbEl.innerHTML='<div style="background:var(--red-bg);border:1px solid rgba(192,57,43,0.2);border-radius:9px;padding:10px 14px;color:var(--red)">❌ Passwords do not match.</div>'; return; }

  const pwds = loadPasswords();
  pwds[account] = newPass;
  savePasswordsToDisk(pwds);

  fbEl.innerHTML=`<div style="background:var(--green-bg);border:1px solid rgba(26,107,74,0.2);border-radius:9px;padding:10px 14px;color:var(--primary)">✅ ${account.charAt(0).toUpperCase()+account.slice(1)} password updated successfully!</div>`;
  clearOnePwdFields(account);
  const dispEl = document.getElementById('disp-'+account+'-pwd');
  if(dispEl) dispEl.textContent = newPass;
  showToast('✅ '+account+' password saved!', 'var(--primary)');
}

function autoGenOne(account) {
  if(currentUser && currentUser.role !== 'admin') { alert('Admin access required.'); return; }
  const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789@#$!';
  const len = account === 'admin' ? 12 : 10;
  const gen = Array.from({length:len}, ()=>chars[Math.floor(Math.random()*chars.length)]).join('');

  const newEl = document.getElementById('new-'+account+'-pass'), confEl = document.getElementById('confirm-'+account+'-pass');
  newEl.value = gen; confEl.value = gen;
  newEl.type = 'text'; confEl.type = 'text';
  checkStrength(account); checkMatch(account);

  const fbEl = document.getElementById(account+'-pwd-feedback');
  fbEl.style.display='block';
  fbEl.innerHTML=`<div style="background:var(--blue-bg);border:1px solid rgba(26,95,138,0.2);border-radius:9px;padding:10px 14px;color:var(--blue)">✨ <strong>Generated password:</strong> <code style="background:rgba(26,95,138,0.1);padding:2px 8px;border-radius:5px;font-family:monospace;font-size:13px">${gen}</code><br><span style="font-size:11px;opacity:0.8;margin-top:4px;display:block">⚠️ Copy this before clicking Save.</span></div>`;
}

function clearOnePwdFields(account) {
  ['new-'+account+'-pass','confirm-'+account+'-pass'].forEach(id=>{
    const el=document.getElementById(id); if(el){el.value='';el.type='password';}
  });
  const bar=document.getElementById(account+'-strength-bar'), txt=document.getElementById(account+'-strength-text'), hint=document.getElementById(account+'-match-hint');
  if(bar){bar.style.width='0%';bar.className='pwd-strength-bar';}
  if(txt) txt.textContent='';
  if(hint) hint.textContent='';
}

